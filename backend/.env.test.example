# Backend test environment template
# Copy to .env.test.local (preferred) or .env.test for local test runs.

NODE_ENV=test
PORT=3000
TEAM_CHAT_ENABLED=true
TEAM_CHAT_REALTIME_ENABLED=true

DB_HOST=localhost
DB_PORT=8012
DB_NAME=nonprofit_manager
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=test_jwt_secret_local_only
JWT_EXPIRES_IN=24h
EXPOSE_AUTH_TOKENS_IN_RESPONSE=true
BYPASS_REGISTRATION_POLICY_IN_TEST=true
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10000
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000
ENABLE_ACCOUNT_LOCKOUT_IN_TEST=true

# Organization context settings
ORG_CONTEXT_REQUIRE=false
ORG_CONTEXT_VALIDATE=false
ORG_ACCESS_VALIDATE=false
