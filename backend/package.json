{
  "name": "nonprofit-manager-backend",
  "version": "0.1.0",
  "description": "Backend API for Nonprofit Manager platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --ignoreDeprecations 6.0 && tsc-alias",
    "start": "node dist/index.js",
    "start:public": "node dist/public-site.js",
    "dev:watch": "node --watch --require ts-node/register/transpile-only -r tsconfig-paths/register",
    "dev": "npm run dev:watch -- src/index.ts",
    "dev:public": "npm run dev:watch -- src/public-site.ts",
    "worker:dev": "npm run dev:watch -- src/worker.ts",
    "worker:start": "node dist/worker.js",
    "auth:reset-state": "ts-node -r tsconfig-paths/register --transpileOnly scripts/reset-auth-state.ts",
    "test": "bash scripts/run-full-tests.sh",
    "test:watch": "jest --watch",
    "test:coverage": "NODE_OPTIONS=\"${NODE_OPTIONS:---max-old-space-size=8192}\" bash scripts/run-full-tests.sh --coverage",
    "test:unit": "jest --forceExit --testPathIgnorePatterns=__tests__/integration/",
    "test:unit:coverage": "NODE_OPTIONS=\"${NODE_OPTIONS:---max-old-space-size=8192}\" JEST_RELAX_COVERAGE_THRESHOLDS=1 jest --forceExit --coverage --testPathIgnorePatterns=__tests__/integration/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit --ignoreDeprecations 6.0"
  },
  "keywords": [
    "nonprofit",
    "management",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mailchimp/mailchimp_marketing": "^3.0.80",
    "@sentry/node": "^10.51.0",
    "@simplewebauthn/server": "^13.3.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "logform": "^2.7.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "redis": "^5.12.1",
    "speakeasy": "^2.0.0",
    "stripe": "^22.1.0",
    "twilio": "^6.0.0",
    "undici": "^8.2.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "exceljs@4.4.0": {
      "uuid": "^14.0.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@nonprofit-manager/contracts": "file:../contracts",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailchimp__mailchimp_marketing": "^3.0.22",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
