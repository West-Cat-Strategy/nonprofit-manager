{
  "name": "nonprofit-manager-backend",
  "version": "0.1.0",
  "description": "Backend API for Nonprofit Manager platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "start:public": "node dist/public-site.js",
    "dev:watch": "node --watch --require ts-node/register/transpile-only -r tsconfig-paths/register",
    "dev": "npm run dev:watch -- src/index.ts",
    "dev:public": "npm run dev:watch -- src/public-site.ts",
    "worker:dev": "npm run dev:watch -- src/worker.ts",
    "worker:start": "node dist/worker.js",
    "imported:import": "ts-node -r tsconfig-paths/register --transpileOnly scripts/import-imported-unified-dataset.ts",
    "imported:audit": "ts-node -r tsconfig-paths/register --transpileOnly scripts/audit-imported-import.ts",
    "imported:reset": "ts-node -r tsconfig-paths/register --transpileOnly scripts/reset-imported-import.ts",
    "auth:reset-state": "ts-node -r tsconfig-paths/register --transpileOnly scripts/reset-auth-state.ts",
    "test": "bash scripts/run-full-tests.sh",
    "test:watch": "jest --watch",
    "test:coverage": "bash scripts/run-full-tests.sh --coverage",
    "test:unit": "jest --forceExit --testPathIgnorePatterns=src/__tests__/integration/",
    "test:unit:coverage": "JEST_RELAX_COVERAGE_THRESHOLDS=1 jest --forceExit --coverage --testPathIgnorePatterns=src/__tests__/integration/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "schema:export": "ts-node --transpileOnly scripts/export-schema-bundle.ts",
    "test:integration": "bash scripts/run-integration-tests.sh",
    "test:integration:coverage": "jest --forceExit --coverage src/__tests__/integration"
  },
  "keywords": [
    "nonprofit",
    "management",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mailchimp/mailchimp_marketing": "^3.0.80",
    "@otplib/preset-default": "^12.0.1",
    "@sentry/node": "^10.43.0",
    "@simplewebauthn/server": "^13.3.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "redis": "^5.10.0",
    "stripe": "^20.4.1",
    "twilio": "^5.13.1",
    "undici": "^7.24.5",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "test-exclude": {
      "minimatch": "3.1.5"
    },
    "ajv": "^6.14.0",
    "brace-expansion": "^2.0.3",
    "flatted": "^3.4.2",
    "handlebars": "^4.7.9",
    "path-to-regexp": "^8.4.0",
    "glob": {
      "minimatch": "3.1.5"
    },
    "readdir-glob": {
      "minimatch": "5.1.9"
    },
    "@sentry/node": {
      "minimatch": "10.2.5"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailchimp__mailchimp_marketing": "^3.0.22",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.1.0",
    "express-validator": "^7.3.2",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "minimatch": "3.1.5",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
