# Frontend Environment Variables

# API URL
VITE_API_URL=HTTP://localhost:3000/api
VITE_DEFAULT_ORGANIZATION_ID=
VITE_TEAM_CHAT_ENABLED=true
VITE_TEAM_CHAT_REALTIME_ENABLED=true
VITE_UI_REDESIGN_ENABLED=true
VITE_UI_SETUP_REQUIRED=
VITE_UI_STAFF_BOOTSTRAP_MODE=
VITE_UI_PORTAL_BOOTSTRAP_MODE=

# Dev Mode Auto-Login (NEVER enable in production)
# Set to "true" to auto-authenticate as dev user in development mode
VITE_DEV_AUTO_LOGIN=false
