# E2E Test Environment Configuration
# Copy to .env.test.local (preferred) or .env.test and adjust values as needed.

# Application URLs
BASE_URL=http://127.0.0.1:5173
API_URL=http://127.0.0.1:3001
TEAM_CHAT_ENABLED=true
VITE_TEAM_CHAT_ENABLED=true
TEAM_CHAT_REALTIME_ENABLED=true
VITE_TEAM_CHAT_REALTIME_ENABLED=true

# Test User Credentials
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_USER_NAME=Test User

# Optional Admin User Credentials Override
# Leave blank to use the runtime-specific defaults:
# - Playwright-managed runtime: admin@example.com / Admin123!@#
# - Docker-backed starter-only runtime from make docker-up-dev: admin@example.com / Admin123!@#
# - Docker-backed runtime seeded with database/seeds/003_mock_data.sql: admin@example.com / password123
ADMIN_USER_EMAIL=
ADMIN_USER_PASSWORD=
ADMIN_USER_NAME=Admin User

# Database
TEST_DB_NAME=nonprofit_manager_test
DB_HOST=127.0.0.1
DB_PORT=8012
DB_NAME=nonprofit_manager_test
DB_USER=postgres
DB_PASSWORD=postgres

# Test Execution Settings
HEADLESS=true
SLOW_MO=0
TIMEOUT=60000
# Direct-registration and shared-user fallback are only used for externally
# managed runtimes that set `SKIP_WEBSERVER=1` with this flag set to `true`.
# The wrapper-driven host commands hard-set this flag to `false`, and the
# wrapper-driven docker commands hard-set it to `true`.
BYPASS_REGISTRATION_POLICY_IN_TEST=true

# Screenshots and Videos
SCREENSHOT_PATH=./test-results/screenshots
VIDEO_PATH=./test-results/videos
