# Copy this file to .env.opensearch before starting the OpenSearch overlay.
# The copied live env file stays local-only and ignored; this tracked file is the template.

OPENSEARCH_INITIAL_ADMIN_PASSWORD=replace-with-a-long-random-password
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=replace-with-a-long-random-password

# Keep heap small for local validation. Resize before production use.
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
