# Development Environment Variables
# These are safe defaults for local development with Docker Compose.
# Copy to .env.development and replace any placeholder values you do not want to reuse locally.
# The copied live env file stays local-only and ignored; this tracked file is the template.

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Public website runtime port for Docker Compose overlays
PUBLIC_SITE_PORT=8006
# Public website host for Docker+Caddy local links. Compose maps this to SITE_BASE_URL.
DEV_SITE_BASE_URL=http://sites.localhost
CADDY_PUBLIC_SITE_DOMAIN=sites.localhost
PUBLIC_SITE_API_ORIGIN=http://sites.localhost

# Database - Local PostgreSQL in Docker
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nonprofit_manager
DB_USER=nonprofit_app_user
DB_PASSWORD=nonprofit_app_password
POSTGRES_PASSWORD=postgres

# Redis Cache - Local Redis in Docker
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

# Background worker and schedulers
# Schedulers are disabled by default. Enable a scheduler only on the single worker
# process intended to own that scheduler for the environment.
# Set WORKER_INSTANCE_ID to a unique stable value when enabling schedulers so
# scheduler-health rows identify the owning process clearly.
WORKER_INSTANCE_ID=worker-dev
EVENT_REMINDER_SCHEDULER_ENABLED=false
EVENT_REMINDER_SCHEDULER_INTERVAL_MS=60000
EVENT_REMINDER_SCHEDULER_BATCH_SIZE=25
EVENT_REMINDER_SCHEDULER_RETRY_ATTEMPTS=1
EVENT_REMINDER_SCHEDULER_RETRY_DELAY_MS=1000
EVENT_REMINDER_SCHEDULER_TIMEOUT_MS=60000
FOLLOW_UP_REMINDER_SCHEDULER_ENABLED=false
FOLLOW_UP_REMINDER_SCHEDULER_INTERVAL_MS=60000
FOLLOW_UP_REMINDER_SCHEDULER_BATCH_SIZE=25
APPOINTMENT_REMINDER_SCHEDULER_ENABLED=false
APPOINTMENT_REMINDER_SCHEDULER_INTERVAL_MS=60000
APPOINTMENT_REMINDER_SCHEDULER_BATCH_SIZE=25
APPOINTMENT_REMINDER_SCHEDULER_RETRY_ATTEMPTS=1
APPOINTMENT_REMINDER_SCHEDULER_RETRY_DELAY_MS=1000
APPOINTMENT_REMINDER_SCHEDULER_TIMEOUT_MS=60000
SCHEDULED_REPORT_SCHEDULER_ENABLED=false
SCHEDULED_REPORT_SCHEDULER_INTERVAL_MS=60000
SCHEDULED_REPORT_SCHEDULER_BATCH_SIZE=10
SCHEDULED_REPORT_SCHEDULER_RETRY_ATTEMPTS=1
SCHEDULED_REPORT_SCHEDULER_RETRY_DELAY_MS=1000
SCHEDULED_REPORT_SCHEDULER_TIMEOUT_MS=120000
LOCAL_CAMPAIGN_DELIVERY_SCHEDULER_ENABLED=false
LOCAL_CAMPAIGN_DELIVERY_SCHEDULER_INTERVAL_MS=60000
LOCAL_CAMPAIGN_DELIVERY_SCHEDULER_BATCH_SIZE=10
LOCAL_CAMPAIGN_DELIVERY_SCHEDULER_RETRY_ATTEMPTS=1
LOCAL_CAMPAIGN_DELIVERY_SCHEDULER_RETRY_DELAY_MS=1000
LOCAL_CAMPAIGN_DELIVERY_SCHEDULER_TIMEOUT_MS=120000
REPORT_PUBLIC_SNAPSHOT_CLEANUP_ENABLED=false
REPORT_PUBLIC_SNAPSHOT_CLEANUP_INTERVAL_MS=600000
REPORT_PUBLIC_SNAPSHOT_CLEANUP_BATCH_SIZE=25
REPORT_PUBLIC_SNAPSHOT_CLEANUP_RETRY_ATTEMPTS=1
REPORT_PUBLIC_SNAPSHOT_CLEANUP_RETRY_DELAY_MS=1000
REPORT_PUBLIC_SNAPSHOT_CLEANUP_TIMEOUT_MS=120000
REPORT_PUBLIC_SNAPSHOT_RETENTION_DAYS=90
REPORT_PUBLIC_SNAPSHOT_ROW_CAP=10000
SOCIAL_MEDIA_SYNC_SCHEDULER_ENABLED=false
SOCIAL_MEDIA_SYNC_INTERVAL_MS=300000
SOCIAL_MEDIA_SYNC_BATCH_SIZE=25
WEBHOOK_RETRY_SCHEDULER_ENABLED=false
WEBHOOK_RETRY_SCHEDULER_INTERVAL_MS=60000
WEBHOOK_RETRY_SCHEDULER_BATCH_SIZE=100
WEBHOOK_RETRY_SCHEDULER_RETRY_ATTEMPTS=1
WEBHOOK_RETRY_SCHEDULER_RETRY_DELAY_MS=1000
WEBHOOK_RETRY_SCHEDULER_TIMEOUT_MS=30000

# JWT - Development secret (NOT for production)
JWT_SECRET=change-me-local-dev-jwt-secret-minimum-32-chars
JWT_EXPIRES_IN=24h
EXPOSE_AUTH_TOKENS_IN_RESPONSE=false

# CSRF Protection - Development secret (NOT for production)
CSRF_SECRET=change-me-local-dev-csrf-secret-minimum-32-chars

# Encryption Key (for PII encryption at rest)
# Local-development example only. Generate a unique 64-hex-character key for any shared or production-like environment.
ENCRYPTION_KEY=1111111111111111111111111111111122222222222222222222222222222222

# MFA (TOTP)
TOTP_ISSUER=Nonprofit Manager

# Passkeys (WebAuthn) - Local development
WEBAUTHN_RP_NAME=Nonprofit Manager
WEBAUTHN_ORIGIN=http://localhost:5173
WEBAUTHN_RP_ID=localhost

# CORS - Allow local frontend
CORS_ORIGIN=http://localhost:5173,http://localhost:8005

# Stripe - Test mode keys (provided by Stripe for testing)
STRIPE_SECRET_KEY=sk_test_change_me_local_only
STRIPE_PUBLISHABLE_KEY=pk_test_change_me_local_only
STRIPE_WEBHOOK_SECRET=whsec_change_me_local_only

# Health Check
HEALTH_CHECK_KEY=local-dev-health-check-key

# Metrics
METRICS_AUTH_KEY=local-dev-metrics-auth-key

# Mailchimp (optional for development)
MAILCHIMP_API_KEY=change-me-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us1

# Mautic (optional for development)
MAUTIC_BASE_URL=https://mautic.example.org
MAUTIC_USERNAME=change-me-mautic-api-user
MAUTIC_PASSWORD=change-me-mautic-api-password
# Plausible Analytics (optional for development)
PLAUSIBLE_API_KEY=change-me-plausible-api-key
PLAUSIBLE_API_HOST=https://plausible.io
PLAUSIBLE_DOMAIN=localhost

# Security Configuration
ENFORCE_SECURE_CONFIG=false
ORG_CONTEXT_REQUIRE=true
ORG_CONTEXT_VALIDATE=true

# Sentry Error Tracking (optional for development)
SENTRY_DSN=
RELEASE_VERSION=development

# Content Security Policy (CSP) Report URI (optional)
CSP_REPORT_URI=

# API Origin (for CORS connectSrc directive)
API_ORIGIN=http://localhost:3000

# Log Aggregation (optional - for centralized log collection)
# See docs/LOG_AGGREGATION_SETUP.md for configuration details
LOG_AGGREGATION_ENABLED=false
# LOG_AGGREGATION_HOST=localhost
# LOG_AGGREGATION_PORT=8080
# LOG_AGGREGATION_PATH=/logs
# LOG_AGGREGATION_PROTOCOL=http
# LOG_AGGREGATION_API_KEY=
