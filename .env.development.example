# Development Environment Variables
# These are safe defaults for local development with Docker Compose.
# Copy to .env.development and replace any placeholder values you do not want to reuse locally.

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Public website runtime port for Docker Compose overlays
PUBLIC_SITE_PORT=8006

# Database - Local PostgreSQL in Docker
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nonprofit_manager
DB_USER=postgres
DB_PASSWORD=postgres
POSTGRES_PASSWORD=postgres

# Redis Cache - Local Redis in Docker
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

# JWT - Development secret (NOT for production)
JWT_SECRET=change-me-local-dev-jwt-secret-minimum-32-chars
JWT_EXPIRES_IN=24h
EXPOSE_AUTH_TOKENS_IN_RESPONSE=false

# CSRF Protection - Development secret (NOT for production)
CSRF_SECRET=change-me-local-dev-csrf-secret-minimum-32-chars

# Encryption Key (for PII encryption at rest)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# MFA (TOTP)
TOTP_ISSUER=Nonprofit Manager

# Passkeys (WebAuthn) - Local development
WEBAUTHN_RP_NAME=Nonprofit Manager
WEBAUTHN_ORIGIN=http://localhost:5173
WEBAUTHN_RP_ID=localhost

# CORS - Allow local frontend
CORS_ORIGIN=http://localhost:5173,http://localhost:8005

# Stripe - Test mode keys (provided by Stripe for testing)
STRIPE_SECRET_KEY=sk_test_change_me_local_only
STRIPE_PUBLISHABLE_KEY=pk_test_change_me_local_only
STRIPE_WEBHOOK_SECRET=whsec_change_me_local_only

# Health Check
HEALTH_CHECK_KEY=local-dev-health-check-key

# Metrics
METRICS_AUTH_KEY=local-dev-metrics-auth-key

# Mailchimp (optional for development)
MAILCHIMP_API_KEY=change-me-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us1

# Mautic (optional for development)
MAUTIC_BASE_URL=https://mautic.example.org
MAUTIC_USERNAME=change-me-mautic-api-user
MAUTIC_PASSWORD=change-me-mautic-api-password

# Plausible Analytics (optional for development)
PLAUSIBLE_API_KEY=change-me-plausible-api-key
PLAUSIBLE_API_HOST=https://plausible.io
PLAUSIBLE_DOMAIN=localhost

# Security Configuration
ENFORCE_SECURE_CONFIG=false
ORG_CONTEXT_REQUIRE=true
ORG_CONTEXT_VALIDATE=true

# Sentry Error Tracking (optional for development)
SENTRY_DSN=
RELEASE_VERSION=development

# Content Security Policy (CSP) Report URI (optional)
CSP_REPORT_URI=

# API Origin (for CORS connectSrc directive)
API_ORIGIN=http://localhost:3000

# Log Aggregation (optional - for centralized log collection)
# See docs/LOG_AGGREGATION_SETUP.md for configuration details
LOG_AGGREGATION_ENABLED=false
# LOG_AGGREGATION_HOST=localhost
# LOG_AGGREGATION_PORT=8080
# LOG_AGGREGATION_PATH=/logs
# LOG_AGGREGATION_PROTOCOL=http
# LOG_AGGREGATION_API_KEY=
