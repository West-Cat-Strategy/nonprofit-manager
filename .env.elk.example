# Copy this file to .env.elk before starting the ELK overlay.
# The compose file now defaults Elasticsearch/Kibana/Logstash to authenticated access.

ELK_SECURITY_ENABLED=true
ELASTIC_PASSWORD=replace-with-a-long-random-password

# Optional: override the Elasticsearch user that Kibana and Logstash use.
# The default is the built-in "elastic" user so local setup does not require
# extra bootstrap steps beyond setting ELASTIC_PASSWORD above.
# ELK_ELASTICSEARCH_USERNAME=elastic
